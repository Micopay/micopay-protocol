# Micopay Backend — Local Environment Example

PORT=3000
# We run Postgres on Render (service "micopay-db"), not locally. Copy the
# External Database URL from the Render dashboard into your local .env —
# the Internal URL only resolves inside Render's network.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/micopay_dev

# Stellar Config
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=TESTNET
ESCROW_CONTRACT_ID=C... (Tu contrato desplegado)

# Security
JWT_SECRET=super_secret_jwt_key_for_hackathon
SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# MVP FLAGS
# Set to 'true' to skip real on-chain verification during the demo
MOCK_STELLAR=true

# Demo Mode — NEVER set to true in production; for app store review builds only
DEMO_MODE=false

# Gates cetes/blend/kyc/ramp routes (see src/index.ts) — set true to enable the
# Etherfuse anchor endpoints. Safe for production (unlike DEMO_MODE).
ENABLE_INVESTMENTS=true

# ── ZKaaS ──────────────────────────────────────────────────────────────────────
# ZkVerifierRegistry contract (deployed on Stellar testnet, 3 circuits registered:
# poseidon_preimage, reputation_v1, access_credential_v1). Redeployed 2026-07-02
# with the Fase 0 fixes (refresh_nullifier, longer nullifier TTL).
ZK_VERIFIER_CONTRACT_ID=CCZHC456HBJRTZP45V5AT3ILHP3MOVH36MHR7HUWQHV2JLN6MJEITXB2

# Admin key (needed for register_circuit / set_reputation_root calls only —
# config-changing, low-frequency, ideally kept cold/offline in real deployments)
# Use any funded testnet key — the matching address is the ZkVerifierRegistry admin
ADMIN_SECRET_KEY=

# Operator key (pays gas for verify/verify_unique — the contract requires no
# special admin rights for these, so this can be any funded testnet key, kept
# separate from ADMIN_SECRET_KEY so the admin key never touches the hot,
# request-triggered verify path). Falls back to ADMIN_SECRET_KEY with a
# warning if unset.
OPERATOR_SECRET_KEY=

# WP 0.4: client-generated Merkle roots (POST /credentials/buy Mode A) are
# disabled by default — any payer could otherwise overwrite the shared pool's
# on-chain trust anchor with a tree they fully control. Demo/dev only; the API
# refuses to start with this true in production.
ALLOW_CLIENT_ROOTS=false

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# x402 mock mode — accepts "mock:..." payment headers without hitting Stellar
# NEVER set to true in production (the API asserts this at startup)
X402_MOCK_MODE=true

# ── Etherfuse anchor (SPEI <-> CETES) ───────────────────────────────────────
# Sandbox: create an account at https://sandbox.etherfuse.com, then
# Account -> Manage Accounts -> Sandbox API Keys to generate a key.
ETHERFUSE_API_KEY=
ETHERFUSE_API_URL=https://api.sand.etherfuse.com   # production: https://api.etherfuse.com

# One secret per POST /ramp/webhook subscription (base64, returned once at
# creation time) — see docs/SPEI_ANCHOR_PLAN.md for how these were registered.
ETHERFUSE_WEBHOOK_SECRET_ORDER=
ETHERFUSE_WEBHOOK_SECRET_KYC=
