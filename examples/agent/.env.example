# Copy to .env and fill in.

MICOPAY_API_URL=http://localhost:3000

# Testnet-only EVM key. Needs Base Sepolia USDC — does NOT need Base ETH:
# EIP-3009 authorizations are signed off-chain and gasless from the agent's
# side, MicoPay's relayer/facilitator pays gas to broadcast them.
AGENT_PRIVATE_KEY=

# Must match what MicoPay's API is configured with (apps/api/.env.example) —
# verify on basescan before relying on this for anything beyond a demo.
BASE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Confirmed live via eth_call against this specific contract during WP4
# smoke testing — NOT Circle's usual "USD Coin". If you change
# BASE_USDC_ADDRESS, re-verify: cast call <addr> "name()(string)"
BASE_USDC_DOMAIN_NAME=USDC
BASE_USDC_DOMAIN_VERSION=2
BASE_CHAIN_ID=84532

PROMPT=In one sentence, what is MicoPay?

# Fill these in on your SECOND run, after generating the ZK proof manually
# (this script prints the exact commands the first time you run it).
SPEND_PROOF_B64=
SPEND_PUBLIC_INPUTS=
